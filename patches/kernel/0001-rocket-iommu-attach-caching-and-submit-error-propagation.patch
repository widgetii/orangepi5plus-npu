diff -ruN a/drivers/accel/rocket/rocket_drv.c b/drivers/accel/rocket/rocket_drv.c
--- a/drivers/accel/rocket/rocket_drv.c	2026-03-19 20:35:54.307505821 +0300
+++ b/drivers/accel/rocket/rocket_drv.c	2026-03-19 20:35:54.309776435 +0300
@@ -119,8 +119,19 @@
 rocket_postclose(struct drm_device *dev, struct drm_file *file)
 {
 	struct rocket_file_priv *rocket_priv = file->driver_priv;
+	struct rocket_device *rdev = rocket_priv->rdev;
 
 	rocket_job_close(rocket_priv);
+
+	/* Detach IOMMU domain from any core that has it cached */
+	for (unsigned int core = 0; core < rdev->num_cores; core++) {
+		if (rdev->cores[core].attached_domain == rocket_priv->domain) {
+			iommu_detach_group(rocket_priv->domain->domain,
+					   rdev->cores[core].iommu_group);
+			rdev->cores[core].attached_domain = NULL;
+		}
+	}
+
 	mutex_destroy(&rocket_priv->mm_lock);
 	drm_mm_takedown(&rocket_priv->mm);
 	rocket_iommu_domain_put(rocket_priv->domain);
diff -ruN a/drivers/accel/rocket/rocket_job.c b/drivers/accel/rocket/rocket_job.c
--- a/drivers/accel/rocket/rocket_job.c	2026-03-19 20:35:54.298359781 +0300
+++ b/drivers/accel/rocket/rocket_job.c	2026-03-19 20:35:54.300714103 +0300
@@ -314,9 +314,15 @@
 	if (ret < 0)
 		return fence;
 
-	ret = iommu_attach_group(job->domain->domain, core->iommu_group);
-	if (ret < 0)
-		return fence;
+	/* Skip IOMMU attach if same domain is already attached */
+	if (core->attached_domain != job->domain) {
+		if (core->attached_domain)
+			iommu_detach_group(core->attached_domain->domain, core->iommu_group);
+		ret = iommu_attach_group(job->domain->domain, core->iommu_group);
+		if (ret < 0)
+			return fence;
+		core->attached_domain = job->domain;
+	}
 
 	scoped_guard(mutex, &core->job_lock) {
 		core->in_flight_job = job;
@@ -340,7 +346,7 @@
 				return;
 			}
 
-			iommu_detach_group(NULL, iommu_group_get(core->dev));
+			/* Leave IOMMU domain attached for next job (cache) */
 			dma_fence_signal(core->in_flight_job->done_fence);
 			pm_runtime_put_autosuspend(core->dev);
 			core->in_flight_job = NULL;
@@ -364,7 +370,10 @@
 		if (core->in_flight_job)
 			pm_runtime_put_noidle(core->dev);
 
-		iommu_detach_group(NULL, core->iommu_group);
+		if (core->attached_domain) {
+			iommu_detach_group(core->attached_domain->domain, core->iommu_group);
+			core->attached_domain = NULL;
